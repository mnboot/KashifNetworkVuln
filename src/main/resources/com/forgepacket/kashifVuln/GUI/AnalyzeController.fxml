<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<VBox xmlns:fx="http://javafx.com/fxml/1" prefHeight="400.0" prefWidth="600.0" stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.forgepacket.kashifVuln.GUI.AnalyzeController">
    <VBox alignment="CENTER" prefHeight="62.0" prefWidth="600.0">
        <Label text="Input File from 'Capture' tab">
            <font>
                <Font size="18.0"/>
            </font>
        </Label>
        <Label fx:id="lblStatus" style="-fx-text-fill: red" text="Status: not opened">
            <font>
                <Font size="25.0"/>
            </font>
        </Label>
    </VBox>
    <BarChart fx:id="barChart" title="Protocol Statistics" animated="false">
        <xAxis>
            <CategoryAxis label="Protocol" side="BOTTOM" tickLabelFill="WHITE"/>
        </xAxis>
        <yAxis>
            <NumberAxis side="LEFT" tickLabelFill="WHITE" label="Count"/>
        </yAxis>
    </BarChart>
</VBox>
