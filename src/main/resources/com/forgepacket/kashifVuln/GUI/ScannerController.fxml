<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml/1" prefHeight="400.0" prefWidth="600.0" stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/25" fx:controller="com.forgepacket.kashifVuln.GUI.ScannerController">
    <children>
        <HBox alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
              spacing="5.0">
            <children>
                <Label text="Target IP:"/>
                <TextField fx:id="txtTarget"/>
                <Label text="Start:"/>
                <TextField fx:id="txtStart" text="1"/>
                <Label text="End:"/>
                <TextField fx:id="txtEnd" text="1024"/>
                <Button mnemonicParsing="false" onAction="#ocStartScan"
                        text="Start Scan"/>
            </children>
        </HBox>
        <TableView maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="913.0">
            <columns>
                <TableColumn prefWidth="75.0" text="Port"/>
                <TableColumn prefWidth="75.0" text="State"/>
            </columns>
        </TableView>
    </children>
</VBox>
